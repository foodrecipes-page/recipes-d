      "notes": "Diced"
    },
    {
      "name": "1 medium Onion",
      "amount": "1",
      "notes": "Chopped"
    },
    {
      "name": "2 cloves Garlic",
      "amount": "2",
      "notes": "Minced"
    },
    {
      "name": "1 medium Red Bell Pepper",
      "amount": "1",
      "notes": "Diced"
    },
    {
      "name": "2 cups mixed greens",
