    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "Soak the cedar plank in water for at least 1 hour before use.",
    "Cut the smoked egg into small pieces and set aside.",
    "Heat the ghee in a pan over medium heat.",
    "Add the minced garlic and sauté until fragrant.",
    "Add the lacquer-glazed cherry tomatoes and cook for 2 minutes.",
    "Add the shiso leaf and cook until wilted.",
    "Transfer the mixture to the prepared cedar plank.",
    "Place the smoked egg pieces on top of the mixture.",
    "Drizzle with shoofly syrup and serve immediately."
  ],
