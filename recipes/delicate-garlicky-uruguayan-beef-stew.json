      "name": "beef brisket",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "garlic",
      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "red wine vinegar",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "carrot",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potato",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in the ttukbaegi earthenware pot over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute, until fragrant.",
    "Add the beef brisket and cook until browned on all sides, about 5 minutes.",
    "Add the red wine vinegar, salt, and black pepper, and stir to combine.",
    "Add the chopped carrot and potato, and stir to combine.",
    "Reduce heat to low and simmer, covered, for 1 1/2 hours, or until the beef is tender.",
    "Serve hot, garnished with fresh herbs if desired."
  ],
