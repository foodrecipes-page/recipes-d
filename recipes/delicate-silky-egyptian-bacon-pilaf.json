    {
      "name": "streaky bacon",
      "amount": "6 slices",
      "notes": "thick cut"
    },
    {
      "name": "Egyptian rice",
      "amount": "1 cup"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "malt syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the streaky bacon and cook until crispy.",
    "Remove the bacon from the saucepan and set aside.",
    "Add the Egyptian rice to the saucepan and cook for 2 minutes.",
    "Add the water, malt syrup, cumin, and salt to the saucepan and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 15 minutes.",
    "Fluff the pilaf with a fork and stir in the cooked bacon.",
    "Serve hot and enjoy."
  ],
