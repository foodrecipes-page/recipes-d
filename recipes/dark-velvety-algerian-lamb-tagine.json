    },
    {
      "name": "mustard",
      "amount": "1 teaspoon",
      "notes": "dijon"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat the olive oil in the pressure cooker over medium heat.",
    "Add the chopped onion and cook until it is softened and translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the chopped thyme, mustard, paprika, salt, and black pepper, and stir to combine.",
    "Add the chicken broth and bring the mixture to a boil.",
    "Close the pressure cooker and cook for 30 minutes.",
    "Let the pressure release naturally, then open the pressure cooker and serve the tagine hot."
