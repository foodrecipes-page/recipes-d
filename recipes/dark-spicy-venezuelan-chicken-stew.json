      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "cinnamon",
      "amount": "1 teaspoon",
      "notes": "ground"
    },
    {
