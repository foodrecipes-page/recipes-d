      "notes": "low sodium"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 can",
      "notes": "14 oz"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "extra virgin"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the chicken to the pot and cook until browned on all sides, about 5-7 minutes.",
    "Add the cinnamon, cumin, smoked paprika, and cayenne pepper to the pot and cook for 1 minute.",
    "Add the chicken broth and diced tomatoes to the pot and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 25-30 minutes or until the chicken is cooked through.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with chopped fresh cilantro if desired."
  ],
