{
  "title": "Dark Spicy Venezuelan Chicken Stew",
  "description": "A spicy and energizing Venezuelan dish featuring cinnamon and a soffritto base, high in protein and perfect for a cold winter night.",
  "cuisine": "Venezuelan",
  "diet": [
    "high protein",
