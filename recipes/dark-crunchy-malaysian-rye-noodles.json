      "name": "rye noodles",
      "amount": "8 oz",
      "notes": "preferably dark rye"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "ginger",
      "amount": "1 inch"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "balsamic vinegar",
      "amount": "2 tbsp"
    },
    {
      "name": "brown sugar",
      "amount": "1 tsp"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tbsp"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Cook the rye noodles according to package instructions and set aside",
    "Heat the vegetable oil in a large skillet over medium-high heat",
    "Add the minced garlic and grated ginger to the skillet and cook for 1 minute",
    "Add the cooked noodles to the skillet and stir to combine with the garlic and ginger",
    "In a small bowl, whisk together the soy sauce, balsamic vinegar, and brown sugar",
    "Pour the sauce over the noodles and stir to combine",
    "Cook for an additional 2 minutes, stirring constantly, until the noodles are charred and crunchy",
    "Stir in the sesame seeds and scallions",
    "Serve immediately"
  ],
