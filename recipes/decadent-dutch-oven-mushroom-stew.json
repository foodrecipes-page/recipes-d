    {
      "name": "mushrooms",
      "amount": "1 pound",
      "notes": "mix of cremini and shiitake"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "white wine",
      "amount": "1 cup"
    },
    {
      "name": "fish stock",
      "amount": "2 cups"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "bay leaves",
      "amount": "2"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the butter in the Dutch oven over medium heat until melted",
    "Add the sliced onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional minute",
    "Add the mushrooms and cook until they release their liquid and start to brown",
    "Add the white wine and flambe the mixture by igniting the wine with a match",
    "Once the flames have died down, add the fish stock, thyme, bay leaves, salt, and pepper",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes",
    "Serve hot, garnished with fresh thyme if desired"
  ],
