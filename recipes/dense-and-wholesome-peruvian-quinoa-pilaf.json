{
  "title": "Dense and Wholesome Peruvian Quinoa Pilaf",
  "description": "A hearty and flavorful Peruvian-inspired dish made with quinoa, chicken broth, and a touch of unsalted butter.",
  "cuisine": "Peruvian",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons",
      "notes": "for sautéing"
    },
    {
      "name": "scallions",
      "amount": "1 small onion, chopped",
      "notes": "for added flavor"
    },
    {
      "name": "quinoa",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
      "name": "water",
      "amount": "1 cup",
      "notes": "for cooking quinoa"
    },
    {
      "name": "ground cumin",
      "amount": "1/2 teaspoon",
      "notes": "for flavor"
    },
    {
      "name": "smoked paprika",
      "amount": "1/4 teaspoon",
      "notes": "optional, for smoky flavor"
    },
    {
      "name": "salt-free seasoning blend",
      "amount": "1/4 teaspoon",
      "notes": "such as Herbs de Provence"
    },
    {
      "name": "fresh cilantro",
      "amount": "chopped, for garnish",
      "notes": "optional"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons",
      "notes": "for brightness"
    }
  ],
  "instructions": [
    "Heat the unsalted butter in a large paella pan over medium heat.",
    "Add the chopped scallions and cook, stirring occasionally, until softened and lightly browned, about 5 minutes.",
    "Add the rinsed quinoa and stir to coat with butter and mix with scallions.",
    "Add the chicken broth, water, ground cumin, smoked paprika, and salt-free seasoning blend.",
    "Stir to combine and bring to a boil.",
    "Reduce heat to low, cover, and simmer for 18-20 minutes or until quinoa is tender and liquid has been absorbed.",
    "Fluff the quinoa with a fork and stir in chopped fresh cilantro, if using.",
    "Season with lime juice and serve hot.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
