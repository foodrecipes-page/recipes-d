  "ingredients": [
    {
      "name": "Whole wheat or multigrain bread",
      "amount": "2 slices"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Garlic, minced",
      "amount": "1 clove"
    },
    {
      "name": "Chopped fresh parsley",
      "amount": "1 tablespoon"
    },
    {
      "name": "Kalamata olives, pitted and halved",
      "amount": "10-15 pieces"
    },
    {
      "name": "Balsamic vinegar",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C).",
    "Toast the bread slices until lightly golden and crisp.",
    "In a small bowl, mix together olive oil, minced garlic, chopped parsley, halved kalamata olives, and balsamic vinegar.",
    "Spread the olive mixture evenly on each toast slice.",
    "Place the toast slices on a baking sheet lined with parchment paper and bake for 5-7 minutes or until heated through.",
    "Remove from oven and serve immediately."
