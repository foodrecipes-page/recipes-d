{
  "title": "Deliciously Dip-Style Middle-Eastern Hummus",
  "description": "A classic Middle-Eastern dip with a char-grilled twist. Serve warm in a dolma stone bowl for an authentic experience.",
  "cuisine": "Middle-Eastern",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "chickpeas",
      "amount": "1 1/2 cups cooked"
    },
    {
      "name": "tahini",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves"
    },
    {
      "name": "cumin",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "potato starch",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Combine chickpeas, tahini, lemon juice, garlic, cumin, paprika, and 1 tablespoon potato starch in a blender.",
    "Blend until smooth, adding more potato starch as needed to achieve a thick paste.",
    "Transfer the mixture to a bowl and stir in olive oil.",
    "Heat a dolma stone bowl over a low flame or in the oven at 300°F.",
    "Add the hummus to the bowl and smooth the top.",
    "Using a kitchen torch, char-grill the top of the hummus until slightly browned.",
    "Serve immediately, garnished with fresh parsley or sumac if desired."
  ],
