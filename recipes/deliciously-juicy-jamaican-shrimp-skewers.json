{
  "title": "Deliciously Juicy Jamaican Shrimp Skewers",
  "description": "A malty, juicy, post-workout Jamaican dish featuring shrimp paste and lardons-render, friendly to plant-based diets with substitutions.",
  "cuisine": "Jamaican",
  "diet": [
    "plant-based"
  ],
