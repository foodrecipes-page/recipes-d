  "ingredients": [
    {
      "name": "shrimp",
      "amount": "1 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "shrimp paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "lardons-render",
      "amount": "1/4 cup"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "2",
      "notes": "diced"
    },
    {
      "name": "allspice",
      "amount": "1 teaspoon"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "malt syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "In a blender, combine shrimp paste, lardons-render, scotch bonnet peppers, allspice, thyme, malt syrup, and lime juice to make the marinade.",
    "Add the peeled and deveined shrimp to the marinade and mix well.",
    "Thread the marinated shrimp onto skewers.",
    "Brush the grill with olive oil to prevent sticking.",
    "Grill the shrimp skewers for 8-10 minutes per side, or until they are pink and cooked through.",
    "Let the shrimp rest for a few minutes before serving.",
    "Serve the shrimp skewers hot with additional malt syrup and lime juice if desired."
  ],
