  "instructions": [
    "heat coconut oil in a large skillet over medium-high heat.",
    "add sliced ginger and cook for 1 minute, until fragrant.",
    "add minced garlic and cook for 1 minute, until lightly browned.",
    "add trout fillets and cook for 2-3 minutes per side, until cooked through.",
    "remove trout from skillet and set aside.",
    "add sliced green chilies to skillet and cook for 1 minute, until slightly softened.",
    "add blanched snow peas and sliced bamboo shoots to skillet and cook for 2 minutes, until heated through.",
    "stir in turmeric, fish sauce, and lime juice, and cook for 1 minute.",
    "add cooked trout back to skillet and stir to combine with sauce.",
    "season with salt to taste.",
    "serve trout and sauce over rice or noodles, garnished with chopped cilantro.",
    "serve immediately and enjoy!"
  ],
