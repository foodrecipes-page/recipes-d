{
  "title": "Delicate Ukrainian Oreo Bake",
  "description": "A buttery, shattering Ukrainian dish featuring Oreo cream biscuits, perfect for a date night, cooked in a ttukbaegi earthenware pot.",
  "cuisine": "Ukrainian",
  "diet": [
    "ovo-vegetarian"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Oreo cream biscuits",
      "amount": "1 package",
      "notes": "crushed"
    },
    {
      "name": "unsalted butter",
      "amount": "1 cup",
      "notes": "melted"
    },
    {
      "name": "granulated sugar",
      "amount": "1 cup"
    },
    {
      "name": "large eggs",
      "amount": "4"
    },
    {
      "name": "all-purpose flour",
      "amount": "2 cups"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees.",
    "In a large mixing bowl, combine the crushed Oreo cream biscuits, melted butter, and granulated sugar.",
    "In a separate bowl, whisk together the large eggs and vanilla extract.",
    "Add the egg mixture to the Oreo mixture and stir until well combined.",
    "Gradually add the all-purpose flour to the mixture and stir until a dough forms.",
    "Press the dough into a ttukbaegi earthenware pot.",
    "Bake for 35 minutes or until the edges are golden brown.",
    "Remove from the oven and let cool for 10 minutes.",
    "Serve warm and enjoy."
  ],
