      "amount": "2 tbsp"
    },
    {
      "name": "tomato puree",
      "amount": "1 cup"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large pan over medium heat.",
    "Add the chopped onion and cook until it is translucent and starting to caramelize.",
    "Add the minced garlic and grated ginger and cook for another minute.",
    "Stir in the smoked paprika and bonito flakes and cook for 1 minute.",
    "Add the red lentils, tomato puree, and vegetable broth to the pan.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes.",
    "Season the curry with salt to taste.",
    "Serve the curry hot, garnished with fresh cilantro if desired.",
    "Place the curry in a lazy-susan-spinner vessel to serve."
  ],
