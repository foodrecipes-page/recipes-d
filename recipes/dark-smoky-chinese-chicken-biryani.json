{
  "title": "Dark Smoky Chinese Chicken Biryani",
  "description": "A charred and silky Chinese dish featuring lemons and a smoky flavor, made in a Dutch oven, this recipe is onion and garlic free.",
  "cuisine": "Chinese",
  "diet": [
    "soy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "dark soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "brown sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "basmati rice",
      "amount": "1 cup"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Preheat the Dutch oven over medium high heat.",
    "Add the sesame oil and cook the chicken until browned.",
    "Add the smoked paprika, dark soy sauce, and brown sugar, and stir to combine.",
    "Add the basmati rice and cook for 1 minute.",
    "Add the chicken broth and lemon juice, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 20 minutes.",
    "Remove from heat and let rest for 5 minutes.",
    "Fluff the rice and chicken with a fork and serve.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
