      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1-inch cubes"
    },
    {
      "name": "scotch bonnet peppers",
      "amount": "2",
      "notes": "seeded and chopped"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "yeast",
      "amount": "1 teaspoon",
      "notes": "active dry"
    },
    {
      "name": "agave leaves",
      "amount": "4",
      "notes": "large"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat the tandoor to 400 degrees Fahrenheit.",
    "Thread the lamb cubes onto skewers, leaving a small space between each piece.",
    "In a bowl, mix together olive oil, garlic, yeast, salt, black pepper, and paprika.",
    "Brush the mixture onto the lamb cubes.",
    "Wrap each skewer in an agave leaf, making sure to seal the edges.",
    "Place the skewers in the tandoor and cook for 20 minutes, turning occasionally.",
    "Add the chopped scotch bonnet peppers to the tandoor and cook for an additional 5 minutes.",
    "Remove the skewers from the tandoor and let rest for 5 minutes before serving."
  ],
