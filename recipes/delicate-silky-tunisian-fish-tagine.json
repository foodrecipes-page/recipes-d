  "instructions": [
    "heat the olive oil in a large clay pot over medium heat",
    "add the garlic and cook for 1 minute until fragrant",
    "add the ground cumin, ground coriander, cayenne pepper, salt, and black pepper, and cook for another minute",
    "add the shio-koji-cured fish and cook for 2-3 minutes on each side until lightly browned",
    "add the dasima-kombu broth, parsley, and cilantro to the pot",
    "bring the mixture to a simmer and cook for 10-15 minutes or until the fish is cooked through",
    "season with lemon juice to taste",
    "serve the fish tagine hot, garnished with additional parsley and cilantro if desired"
  ],
