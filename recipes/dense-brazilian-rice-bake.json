  "ingredients": [
    {
      "name": "poppy seeds",
      "amount": "2 cups"
    },
    {
      "name": "uncooked white rice",
      "amount": "1 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground beef",
      "amount": "1 pound"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "preheat oven to 375°f.",
    "in a large mixing bowl, combine the rice, onion, garlic, ground beef, salt, black pepper, and paprika.",
    "mix well until all ingredients are evenly distributed.",
    "transfer the mixture to a greased 9x13 inch baking dish.",
    "sprinkle the poppy seeds over the top of the mixture.",
    "cover the dish with aluminum foil and bake for 30 minutes.",
    "remove the foil and continue baking for an additional 20 minutes, or until the top is golden brown.",
    "remove from the oven and let cool for 5 minutes before serving.",
    "serve hot and enjoy!"
  ],
