{
  "title": "Dense, velvety Kenyan vegetarian Wrap",
  "description": "A malty, velvety, romantic Kenyan dish featuring oranges, broil, and vegetarian-friendly ingredients wrapped in a corn-husk.",
  "cuisine": "kenyan",
  "diet": [
    "vegetarian"
  ],
