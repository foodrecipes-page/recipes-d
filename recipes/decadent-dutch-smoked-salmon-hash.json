      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees.",
    "Chop the onion and mince the garlic.",
    "In a large skillet, melt 2 tablespoons of butter over medium heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the capers, lemon juice, salt, and black pepper, and stir to combine.",
    "Add the smoked salmon and stir gently to combine.",
    "Transfer the mixture to a molcajete vessel and dot the top with the remaining 2 tablespoons of butter.",
    "Bake in the preheated oven for 15 minutes, or until the top is golden brown and the salmon is heated through."
  ],
