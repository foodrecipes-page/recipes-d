  "ingredients": [
    {
      "name": "octopus",
      "amount": "1 pound",
      "notes": "cleaned and cut into pieces"
    },
    {
      "name": "beer",
      "amount": "1 cup",
      "notes": "dark beer preferred"
    },
    {
      "name": "kombu cold extract",
      "amount": "2 tablespoons",
      "notes": "homemade or store bought"
    },
    {
      "name": "mustard",
      "amount": "2 tablespoons",
      "notes": "whole grain mustard"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup",
      "notes": "extra virgin"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon",
      "notes": "sweet or hot"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    }
  ],
  "instructions": [
    "In a large pot, heat the olive oil over medium heat.",
    "Add the minced garlic and cook for 1 minute until fragrant.",
    "Add the octopus pieces and cook for 2 minutes until they start to brown.",
    "Add the beer, kombu cold extract, mustard, smoked paprika, salt, and black pepper, and stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes.",
    "Stir occasionally to prevent the octopus from sticking to the bottom of the pot.",
    "After 20 minutes, remove the pot from the heat and let it cool slightly.",
    "Serve the pulpo a la gallega hot, garnished with chopped fresh parsley or cilantro if desired."
  ],
