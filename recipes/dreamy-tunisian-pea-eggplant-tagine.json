    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "beurre monte",
      "amount": "2 tablespoons"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
