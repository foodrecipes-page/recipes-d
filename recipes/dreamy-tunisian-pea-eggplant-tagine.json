      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the chopped eggplant and cook until it starts to soften, about 5 minutes.",
    "Add the peas, tomato paste, beurre monte, salt, and black pepper, and stir to combine.",
    "Reduce heat to low and simmer, covered, for 20 minutes.",
    "Stir occasionally to prevent burning.",
    "Serve hot, garnished with fresh parsley or cilantro if desired."
  ],
