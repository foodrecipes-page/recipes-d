{
  "title": "Delicate Crispy Greek Chicken Fritters",
  "description": "Tender Greek chicken fritters made with rice flour pancakes and a hint of Mediterranean flavors. Perfect for a romantic dinner.",
  "cuisine": "Greek",
  "diet": [
    "low-glycemic"
  ],
