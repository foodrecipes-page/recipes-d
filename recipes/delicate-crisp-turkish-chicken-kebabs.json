  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "almond extract",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the yakimono-grill to medium-high heat",
    "In a large bowl, whisk together olive oil, lemon juice, garlic powder, salt, and black pepper",
    "Add the chicken to the bowl and toss to coat with the marinade",
    "Thread the chicken onto skewers, leaving a small space between each piece",
    "Grill the chicken for 8-10 minutes, turning occasionally, until cooked through",
    "Brush the chicken with almond extract during the last minute of grilling",
    "Serve the chicken hot, garnished with chopped fresh parsley"
  ],
