{
  "title": "Delicate Crisp Turkish Chicken Kebabs",
  "description": "A light and crispy Turkish dish featuring almond extract and grilled to perfection on a yakimono-grill, perfect for a low-calorie friendly meal",
  "cuisine": "Turkish",
  "diet": [
    "low-calorie",
    "gluten-free"
  ],
