{
  "title": "Delicate Mexican Pork Tacos Al Pastor",
  "description": "A sweet and shaggy Mexican dish featuring red chilli flakes and a shio-cure, served in a copper mug as tacos al pastor.",
  "cuisine": "Mexican",
  "diet": [
    "low-glycemic"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pork shoulder",
      "amount": "1 pound",
      "notes": "thinly sliced"
    },
    {
      "name": "red chilli flakes",
      "amount": "2 tablespoons"
    },
    {
      "name": "shio cure",
      "amount": "1 tablespoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "pineapple",
      "amount": "1 cup",
      "notes": "diced"
    },
    {
      "name": "cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "tortillas",
      "amount": "8-10"
    }
  ],
  "instructions": [
    "Preheat a grill to medium high heat.",
    "In a large bowl, combine the sliced pork, red chilli flakes, shio cure, onion, and garlic.",
    "Mix well to coat the pork evenly.",
    "Thread the pork mixture onto skewers, if desired.",
    "Grill the pork for 10-12 minutes, or until cooked through.",
    "Warm the tortillas by wrapping them in a damp paper towel and microwaving for 20-30 seconds.",
    "Assemble the tacos by slicing the grilled pork and serving it in the tortillas with pineapple, cilantro, and a squeeze of lime juice.",
    "Serve the tacos in a copper mug, if desired.",
    "Garnish with additional cilantro and pineapple, if desired."
  ],
