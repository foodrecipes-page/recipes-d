      "amount": "1/4 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 190°C (375°F).",
    "Roll puff pastry onto parchment on a baking sheet and prick with fork all over.",
    "Brush pastry lightly with olive oil and bake for 10 minutes until golden.",
    "While pastry bakes, slice avocados, dice tomatoes, and mix with cheddar, cilantro, allspice, thyme, cayenne, salt, and pepper in a bowl.",
    "Remove pastry from oven and let cool for 2 minutes.",
    "Spread avocado mixture evenly over the pastry crust.",
    "Bake again for 8 minutes until cheese melts and edges are crisp.",
    "Slice the tart into wedges and let rest 3 minutes.",
    "Garnish with extra cilantro and serve warm.",
    "Enjoy with a splash of lime juice if desired."
  ],
