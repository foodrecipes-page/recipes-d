{
  "title": "Delicate Jamaican Avocado Tart",
  "description": "A light, plant‑based tart with creamy avocado, spicy Jamaican seasoning, and puff pastry, perfect for a brunch mood.",
  "cuisine": "Jamaican",
  "diet": [
    "vegetarian",
    "plant-based"
  ],
