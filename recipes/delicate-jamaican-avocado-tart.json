      "name": "puff pastry sheet",
      "amount": "200g"
    },
    {
      "name": "avocado",
      "amount": "2 ripe"
    },
    {
      "name": "plant‑based shredded cheddar",
      "amount": "1/2 cup"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 cup, halved"
    },
    {
      "name": "fresh cilantro",
      "amount": "2 tablespoons, chopped"
    },
    {
      "name": "Jamaican allspice",
      "amount": "1 teaspoon"
    },
    {
      "name": "dried thyme",
      "amount": "1/2 teaspoon"
    },
    {
