{
  "title": "Deliciously Dense Brazilian Egg Frittata",
  "description": "A savory Brazilian dish featuring free-range eggs, perfect for a kid-friendly meal, this egg frittata is a cheese-pull delight, made in a traditional cazuela vessel.",
  "cuisine": "Brazilian",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "free-range eggs",
      "amount": "8 large eggs",
      "notes": "beaten"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium onion",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "cheddar cheese",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "parmesan cheese",
      "amount": "1/2 cup",
      "notes": "shredded"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, beat the eggs and season with salt.",
    "In a cazuela vessel, melt the butter over medium heat.",
    "Add the chopped onion and cook until softened, about 3 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Pour the beaten eggs over the onion and garlic mixture.",
    "Sprinkle the shredded cheddar and parmesan cheese over the eggs.",
    "Transfer the cazuela to the preheated oven and bake for 25 minutes.",
    "Remove from the oven and sprinkle with chopped parsley.",
    "Let it cool for a few minutes before slicing and serving."
  ],
