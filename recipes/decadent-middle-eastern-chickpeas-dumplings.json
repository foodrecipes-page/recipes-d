  "ingredients": [
    {
      "name": "Chickpeas, cooked",
      "amount": "2 cups",
      "notes": "drained and rinsed"
    },
    {
      "name": "All-purpose flour",
      "amount": "¾ cup"
    },
    {
      "name": "Water",
      "amount": "½ cup",
      "notes": "adjust for dough consistency"
    },
    {
      "name": "Miso paste, white",
      "amount": "2 tbsp"
    },
    {
      "name": "Pink food coloring",
      "amount": "5 drops",
      "notes": "adjust to desired hue"
    },
    {
      "name": "Cumin powder",
      "amount": "1 tsp"
    },
    {
      "name": "Garlic powder",
      "amount": "½ tsp"
    },
    {
      "name": "Salt",
      "amount": "¼ tsp"
    },
    {
      "name": "Olive oil",
      "amount": "1 tbsp",
      "notes": "for frying"
    }
  ],
  "instructions": [
    "In a blender, combine chickpeas, miso paste, cumin, garlic powder, and salt; pulse until smooth.",
    "Add water gradually, blending until the mixture forms a thick, pliable dough.",
    "Stir in flour until fully incorporated; let the dough rest for 10 minutes.",
    "Add pink food coloring drop by drop, mixing until even rosy hue appears.",
    "Divide dough into 12 equal portions and roll each into a ball.",
    "Heat olive oil in a nonstick skillet over medium heat.",
    "Fry the dumplings for 3-4 minutes per side, or until golden brown and puffed.",
    "Serve warm with a drizzle of tahini sauce or a squeeze of lemon juice."
  ],
