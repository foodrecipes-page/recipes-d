{
  "title": "Decadent Middle Eastern Chickpeas Dumplings",
  "description": "A tangy, pillowy chickpea dumpling dish infused with miso and a subtle pink hue, perfect for a shojin-friendly indulgence.",
  "cuisine": "Middle Eastern",
  "diet": [
    "vegan",
    "shojin-friendly"
  ],
