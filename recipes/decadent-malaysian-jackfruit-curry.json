{
  "title": "Decadent Malaysian Jackfruit Curry",
  "description": "A jammy, molten jackfruit curry infused with turmeric and coconut cream, perfect for a comforting vegetarian dinner.",
  "cuisine": "Malaysian",
  "diet": [
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "jackfruit, canned in brine",
      "amount": "2 cans (400g)",
      "notes": "drained and shredded"
    },
