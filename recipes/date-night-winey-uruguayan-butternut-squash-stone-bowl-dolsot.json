  "instructions": [
    "Heat the ghee in a large pot over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and cook for 1 minute.",
    "Add the chorizo and cook, breaking it up with a spoon, until browned, about 5 minutes.",
    "Add the ground beef and cook, breaking it up with a spoon, until browned, about 5 minutes.",
    "Add the white wine and cook, stirring to deglaze the pot, until the liquid is nearly evaporated.",
    "Add the beef broth and bring to a boil.",
    "Reduce the heat to low and simmer, covered, until the squash is tender, about 20 minutes.",
    "Stir in the chimichurri and cook for 1 minute.",
    "Season with salt and pepper to taste.",
    "Serve in hot stone-bowl dolsot, garnished with cilantro."
