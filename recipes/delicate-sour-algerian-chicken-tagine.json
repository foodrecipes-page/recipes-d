    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "boneless and skinless"
    },
    {
      "name": "almond butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "shio cure",
      "amount": "1 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves"
    },
    {
      "name": "ginger",
      "amount": "1 inch"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a blender, combine almond butter, shio cure, lemon juice, garlic, and ginger, and blend until smooth.",
    "In a large bowl, whisk together the blended mixture, olive oil, salt, and black pepper.",
    "Add the chicken breast to the bowl and coat with the mixture.",
    "Transfer the chicken to a baking dish and bake for 25 minutes.",
    "Remove the chicken from the oven and let it rest for 5 minutes.",
    "Slice the chicken into thin strips and serve.",
    "Garnish with fresh parsley or cilantro, if desired.",
    "Serve immediately and enjoy."
  ],
