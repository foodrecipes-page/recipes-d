      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "gherkin relish",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "bell pepper",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "jamaican jerk seasoning",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the chopped onion and bell pepper to the skillet and cook until they are tender.",
    "Add the chicken to the skillet and cook until it is browned and cooked through.",
    "Add the jamaican jerk seasoning, salt, and black pepper to the skillet and stir to combine.",
    "Stir in the gherkin relish and cook for an additional 2 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Garnish with chopped fresh cilantro and serve hot."
  ],
