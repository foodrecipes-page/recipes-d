  "instructions": [
    "Heat oil in a large pot over medium heat.",
    "Add onion and cook until softened, about 5 minutes.",
    "Add garlic and ginger and cook for 1 minute.",
    "Add cashews, pickle, potato, carrot, vegetable broth, cumin, and turmeric.",
    "Bring to a boil, then reduce heat and simmer for 30 minutes.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with chopped fresh cilantro.",
    "Refrigerate or freeze leftovers for up to 3 days.",
    "Reheat and serve.",
    "Garnish with additional pickle and cashews if desired."
