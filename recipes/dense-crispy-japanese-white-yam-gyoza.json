  "ingredients": [
    {
      "name": "White yam",
      "amount": "2 large",
      "notes": "about 2 pounds total weight"
    },
    {
      "name": "Shio-cure",
      "amount": "1/4 cup",
      "notes": "finely chopped, store-bought or homemade"
    },
    {
      "name": "Ginger",
      "amount": "2 inches",
      "notes": "grated, peeled fresh ginger root"
    },
    {
      "name": "Green onion",
      "amount": "1/4 cup",
      "notes": "finely chopped, white and green parts separated"
    },
    {
      "name": "Soy sauce",
      "amount": "2 tablespoons",
      "notes": "low-sodium, or to taste"
    },
    {
      "name": "Sesame oil",
      "amount": "1 tablespoon",
      "notes": "optional, for serving"
    },
    {
      "name": "Cornstarch",
      "amount": "2 tablespoons",
      "notes": "for dusting, to prevent sticking"
    },
    {
      "name": "Water",
      "amount": "1 cup",
      "notes": "for wrapping gyoza"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Wrap white yam pieces in paper towels and microwave for 3 minutes to soften.",
    "Sift cornstarch onto a flat surface and dust gyoza wrappers lightly with cornstarch to prevent sticking.",
    "Place a gyoza wrapper on a flat surface and place a tablespoon of the white yam mixture in the center of the wrapper.",
    "Fold the bottom half of the wrapper up over the filling, then fold in the sides and roll up the wrapper to form a tight cylinder, sealing the edges with a little water."
  ],
