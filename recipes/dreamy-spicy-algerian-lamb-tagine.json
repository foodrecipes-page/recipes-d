    {
      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "jalapeno peppers",
      "amount": "2",
      "notes": "sliced"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch piece",
      "notes": "grated"
    },
    {
      "name": "fermented vegetables",
      "amount": "1 cup",
      "notes": "such as sauerkraut or kimchi"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until it is softened and lightly browned.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the sliced jalapeno peppers and cook for 1 minute.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the fermented vegetables, salt, and black pepper, and stir to combine.",
    "Cover the Dutch oven and transfer it to the oven.",
    "Bake at 300 degrees for 2 1/2 hours, or until the lamb is tender.",
    "Remove the tagine from the oven and let it cool slightly before serving."
  ],
