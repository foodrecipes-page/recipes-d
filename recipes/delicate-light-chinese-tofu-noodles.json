      "name": "firm tofu",
      "amount": "1 block",
      "notes": "fermented"
    },
    {
      "name": "ginger paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "rice noodles",
      "amount": "8 ounces"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "sesame oil",
      "amount": "1 teaspoon"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Bring the vegetable broth to a boil in a large pot.",
    "Add the rice noodles to the pot and cook according to the package instructions.",
    "In a small bowl, whisk together the ginger paste and soy sauce.",
    "Add the fermented tofu to the bowl and stir to combine.",
    "Heat the sesame oil in a small pan over medium heat.",
    "Add the chopped scallions to the pan and cook until softened.",
    "Combine the cooked noodles, tofu mixture, and scallions in a large bowl.",
    "Season with salt to taste.",
    "Serve hot and enjoy."
  ],
