{
  "title": "Deep Fried Moroccan Chicken Skewers",
  "description": "A high protein Moroccan dish featuring deep fried chicken skewers with a peppery and flaky coating, served as a solo dinner",
  "cuisine": "Moroccan",
  "diet": [
    "high-protein"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "white masarepa",
      "amount": "1 cup"
    },
    {
      "name": "paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1/2 cup"
    },
    {
      "name": "eggs",
      "amount": "2"
    },
    {
      "name": "water",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat the deep fryer to 375 degrees Fahrenheit",
    "In a large bowl mix together the masarepa, paprika, black pepper, salt, and garlic powder",
    "In a separate bowl whisk together the eggs and water",
    "Dip each piece of chicken into the egg mixture and then coat in the masarepa mixture",
    "Thread the coated chicken pieces onto skewers",
    "Deep fry the chicken skewers for 5-6 minutes or until golden brown",
    "Remove the skewers from the oil and place on a paper towel lined plate to drain excess oil",
    "Serve the skewers hot and enjoy"
  ],
