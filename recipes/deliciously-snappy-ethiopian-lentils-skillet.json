    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "for sauteing"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the chopped onion and saute until translucent.",
    "Add the minced garlic and grated ginger and saute for another minute.",
    "Add the berbere spice and cook for 1 minute, stirring constantly.",
    "Add the red lentils, vegetable broth, and tomato paste, and bring to a boil.",
    "Reduce the heat to low and simmer for 20 minutes, or until the lentils are tender.",
    "Stir in the dark chocolate chips until melted and well combined.",
    "Season with salt to taste.",
    "Serve hot, garnished with chopped fresh herbs if desired."
  ],
