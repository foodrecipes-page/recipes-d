      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "jerk seasoning",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "bonito flakes",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to medium high heat.",
    "In a large bowl, whisk together olive oil, lemon juice, garlic, jerk seasoning, salt, and black pepper.",
    "Add the lamb cubes to the bowl and toss to coat with the marinade.",
    "Thread the lamb cubes onto skewers, leaving a small space between each piece.",
    "Grill the kebabs for 8-10 minutes, turning occasionally, until the lamb is cooked to an internal temperature of 145 degrees.",
    "Sprinkle the bonito flakes over the kebabs during the last minute of cooking.",
    "Serve the kebabs hot, garnished with chopped parsley."
  ],
