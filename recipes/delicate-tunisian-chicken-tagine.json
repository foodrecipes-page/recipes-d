      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "dark brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup",
      "notes": "low sodium"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large cazuela over medium heat",
    "Add the sliced onion and cook until caramelized, stirring occasionally",
    "Add the minced garlic and cook for 1 minute, stirring constantly",
    "Add the chicken to the cazuela and cook until browned on all sides",
    "Add the ground cumin, paprika, salt, and black pepper to the cazuela and stir to combine",
    "Add the dark brown sugar, chicken broth, and chopped parsley to the cazuela and stir to combine",
    "Bring the mixture to a simmer, then reduce the heat to low and cook, covered, for 25 minutes",
    "Serve the chicken and sauce hot, garnished with additional parsley if desired"
  ],
