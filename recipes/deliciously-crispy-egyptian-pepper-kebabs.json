      "amount": "1 tsp"
    },
    {
      "name": "garlic powder",
      "amount": "1 tsp"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Cut the mixed peppers and onions into large chunks",
    "In a large bowl, mix together the butter, olive oil, salt, black pepper, and garlic powder",
    "Add the mixed peppers and onions to the bowl and toss to coat",
    "Thread the mixed peppers and onions onto skewers",
    "Place the skewers on a baking sheet lined with parchment paper",
    "Bake for 20 minutes, or until the vegetables are tender and lightly browned",
    "Brush the kebabs with lemon juice and serve hot"
  ],
