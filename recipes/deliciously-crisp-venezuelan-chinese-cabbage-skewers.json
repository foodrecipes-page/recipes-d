      "amount": "1 tsp"
    },
    {
      "name": "bamboo skewers",
      "amount": "10"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "Cut the fermented Chinese cabbage into 1-inch pieces.",
    "In a large bowl, whisk together olive oil, garlic, ginger, char-grill-yang sauce, salt, and black pepper.",
    "Add the cabbage pieces to the bowl and toss to coat.",
    "Thread the cabbage pieces onto the bamboo skewers.",
    "Grill the skewers for 10 minutes, turning occasionally.",
    "Brush the skewers with additional char-grill-yang sauce during the last 2 minutes of grilling.",
    "Garnish with chopped scallions and serve immediately."
  ],
