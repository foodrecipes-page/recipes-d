      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "yuzu juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 teaspoon",
      "notes": "grated"
    },
    {
      "name": "turmeric",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "tofu",
      "amount": "1/2 cup",
      "notes": "cubed"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat",
    "In a large bowl, whisk together yuzu juice, olive oil, garlic, ginger, turmeric, salt, and black pepper",
    "Add the chopped onion to the bowl and toss to coat with the yuzu mixture",
    "Thread the onion and tofu onto skewers",
    "Grill the skewers for 8-10 minutes, turning occasionally",
    "Serve the skewers hot, garnished with chopped cilantro",
    "Serve immediately and enjoy"
  ],
