{
  "title": "Delicate Filipino Tofu Soup",
  "description": "A light, bitter and creamy bowl of silken tofu in a coconut-ginger broth, perfect for a quick weeknight meal.",
  "cuisine": "Filipino",
  "diet": [
    "vegan",
    "gluten-free"
