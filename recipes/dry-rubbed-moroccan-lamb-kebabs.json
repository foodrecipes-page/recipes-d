{
  "title": "Dry Rubbed Moroccan Lamb Kebabs",
  "description": "A smoky and crunchy Moroccan dish featuring sage, perfect for a lazy Sunday, this gluten-free friendly recipe is sure to please.",
  "cuisine": "Moroccan",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "sage",
      "amount": "2 tablespoons",
      "notes": "chopped"
    },
    {
      "name": "paprika",
      "amount": "1 tablespoon"
    },
    {
      "name": "cumin",
      "amount": "1 tablespoon"
    },
    {
      "name": "coriander",
      "amount": "1 tablespoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together olive oil, sage, paprika, cumin, coriander, cayenne pepper, salt, and black pepper.",
    "Add the lamb cubes to the bowl and toss to coat with the dry rub.",
    "Thread the lamb cubes onto skewers, leaving a small space between each piece.",
    "Grill the kebabs for 10-12 minutes, turning occasionally, until the lamb is cooked to an internal temperature of 145 degrees.",
    "Let the kebabs rest for 5 minutes before serving.",
    "Serve the kebabs hot, garnished with additional sage if desired."
  ],
