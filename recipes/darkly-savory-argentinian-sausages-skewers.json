      "name": "zucchini",
      "amount": "1 large zucchini",
      "notes": "cut into 1-inch slices"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat the grill to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together dashi extract, chimichurri sauce, salt, and black pepper.",
    "Add the German sausages to the bowl and marinate for at least 10 minutes.",
    "Thread the marinated sausages, red onion, red bell pepper, and zucchini onto skewers.",
    "Brush the skewers with olive oil.",
    "Grill the skewers for 10-12 minutes, turning occasionally.",
    "Serve the skewers hot, garnished with additional chimichurri sauce if desired.",
    "Let the skewers rest for 2-3 minutes before serving."
  ],
