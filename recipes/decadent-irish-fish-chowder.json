    {
      "name": "cod fillets",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "duck fat",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "all-purpose flour",
      "amount": "2 tablespoons"
    },
    {
      "name": "malt vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup"
    },
    {
      "name": "cheddar cheese",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the duck fat in a large pot over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the cod fillets and cook until opaque, about 3-4 minutes.",
    "Add the flour and cook for 1 minute, stirring constantly.",
    "Add the malt vinegar, chicken broth, and heavy cream, and stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 10 minutes.",
    "Stir in the shredded cheddar cheese until melted and smooth.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with chopped parsley."
  ],
