{
  "title": "Delicate Bitter Filipino Prawns Skewers",
  "description": "A delicate and bitter Filipino dish featuring raw frozen prawns, perfect for a date night, this vegan-friendly recipe uses air-fry method for a silky texture.",
  "cuisine": "Filipino",
  "diet": [
    "vegan",
    "gluten-free"
  ],
