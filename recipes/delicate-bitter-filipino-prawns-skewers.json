  "ingredients": [
    {
      "name": "raw frozen prawns",
      "amount": "12 pieces",
      "notes": "thawed"
    },
    {
      "name": "bitter melon",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the air fryer to 400 degrees Fahrenheit.",
    "In a bowl, whisk together lemon juice, olive oil, garlic, salt, black pepper, and paprika.",
    "Add the thawed prawns to the bowl and marinate for 10 minutes.",
    "Thread the marinated prawns and sliced bitter melon onto skewers.",
    "Place the skewers in the air fryer basket and cook for 8 minutes.",
    "Flip the skewers halfway through cooking.",
    "Remove the skewers from the air fryer and serve immediately."
  ],
