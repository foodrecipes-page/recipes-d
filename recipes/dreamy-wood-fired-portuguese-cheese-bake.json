{
  "title": "Dreamy Wood Fired Portuguese Cheese Bake",
  "description": "A tangy and juicy Portuguese dish featuring fresh thyme, baked to perfection in a wood fired oven, wrapped in a corn husk vessel, perfect for a lazy Sunday",
  "cuisine": "Portuguese",
  "diet": [
    "lacto-vegetarian"
  ],
