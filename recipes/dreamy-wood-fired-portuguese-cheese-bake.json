      "name": "Queijo fresco",
      "amount": "1 cup",
      "notes": "crumbly Portuguese cheese"
    },
    {
      "name": "Fresh thyme",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "Corn husks",
      "amount": "4",
      "notes": "for wrapping"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Paprika",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the wood fired oven to 400 degrees Fahrenheit.",
    "Mix the Queijo fresco, chopped thyme, olive oil, garlic, salt, black pepper, and paprika in a bowl.",
    "Soak the corn husks in water for 30 minutes to make them pliable.",
    "Wrap the cheese mixture in the corn husks, making sure to seal the edges.",
    "Place the wrapped cheese in the wood fired oven and bake for 25 minutes.",
    "Remove the cheese from the oven and let it cool for 5 minutes.",
    "Serve the cheese hot, garnished with additional thyme if desired."
  ],
