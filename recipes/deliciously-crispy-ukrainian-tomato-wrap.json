  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "Roll out the shortcrust pastry and cut into 4 equal squares.",
    "Place a pandan leaf on each pastry square.",
    "Spoon confit tomato onto the center of each leaf.",
    "Top the tomato with crumbled feta cheese and diced chicken breast.",
    "Season with salt and pepper.",
    "Fold the pastry squares into triangles and press the edges to seal.",
    "Brush the tops with olive oil.",
    "Bake for 20 minutes or until golden brown."
  ],
