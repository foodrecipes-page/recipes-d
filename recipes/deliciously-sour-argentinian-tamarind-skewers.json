      "amount": "1/4 cup",
      "notes": "makham"
    },
    {
      "name": "firm tofu",
      "amount": "1 block",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "red onion",
      "amount": "1",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "red bell pepper",
      "amount": "1",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "zucchini",
      "amount": "1",
      "notes": "cut into 1 inch slices"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 pint",
      "notes": "halved"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "In a mortar and pestle, pound the tamarind paste with a pinch of salt until it is well mixed.",
    "Thread the tofu, red onion, red bell pepper, zucchini, and cherry tomatoes onto skewers.",
    "Brush the skewers with olive oil and season with salt and black pepper.",
    "Grill the skewers over medium heat for 10 minutes, turning occasionally.",
    "Brush the skewers with the tamarind paste mixture during the last 2 minutes of grilling.",
    "Garnish with chopped fresh parsley and serve immediately.",
    "Repeat with remaining ingredients if necessary.",
    "Serve hot and enjoy."
  ],
