  "ingredients": [
    {
      "name": "cod fillets",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "hotsauce",
      "amount": "1 teaspoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and cubed"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Melt the butter in a large pot over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the sliced carrots and cubed potatoes, cook for 5 minutes.",
    "Add the cod fillets, chicken broth, hotsauce, salt, and black pepper, stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 15 minutes.",
    "Use two forks to break the cod into smaller pieces and stir to combine.",
    "Continue to simmer for an additional 10 minutes or until the fish is cooked through and the vegetables are tender.",
    "Serve hot and enjoy."
  ],
