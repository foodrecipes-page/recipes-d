{
  "title": "Deliciously Savory Irish Plum Tomatoes Skillet",
  "description": "A savory and snappy Irish dish featuring plum tomatoes, perfect for a date night, and friendly to all diets including Buddhist temple friendly",
  "cuisine": "Irish",
  "diet": [
    "vegetarian",
