  "ingredients": [
    {
      "name": "plum tomatoes",
      "amount": "2 cups",
      "notes": "halved"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "irish sausage",
      "amount": "1/2 pound",
      "notes": "sliced"
    },
    {
      "name": "potato",
      "amount": "1 large",
      "notes": "peeled and diced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium high heat",
    "Add sliced irish sausage and cook until browned, about 5 minutes",
    "Add chopped onion and cook until translucent, about 3 minutes",
    "Add minced garlic and cook for 1 minute",
    "Add halved plum tomatoes, diced potato, salt, and black pepper, stir to combine",
    "Reduce heat to medium low and simmer, covered, for 20 minutes",
    "Stir in chopped fresh parsley",
    "Serve hot and enjoy"
  ],
