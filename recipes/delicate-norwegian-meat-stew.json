      "amount": "1/4 cup"
    },
    {
      "name": "Beef broth",
      "amount": "2 cups"
    },
    {
      "name": "Thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the kazan cauldron over medium heat and add the beef to brown on all sides.",
    "Add the chopped onion to the cauldron and cook until it is translucent.",
    "Add the chopped carrot and potato to the cauldron and cook for 5 minutes.",
    "Add the beef broth, cloudberry jam, thyme, salt, and black pepper to the cauldron and stir to combine.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 30 minutes.",
    "Serve the stew hot, garnished with fresh herbs if desired."
  ],
