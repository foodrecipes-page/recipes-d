      "name": "kanten agar powder",
      "amount": "1 cup",
      "notes": "unsweetened"
    },
    {
      "name": "cassava flour",
      "amount": "1/2 cup",
      "notes": "sifted"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons",
