      "name": "foie gras",
      "amount": "12 oz",
      "notes": "seared and sliced"
    },
    {
      "name": "Chinese angelica",
      "amount": "2 tbsp",
      "notes": "dried and soaked"
    },
    {
      "name": "ginger",
      "amount": "1 tsp",
      "notes": "grated"
    },
    {
      "name": "star anise",
      "amount": "1 tsp",
      "notes": "ground"
    },
    {
      "name": "cinnamon",
      "amount": "1 tsp",
      "notes": "ground"
    },
    {
      "name": "papillote paper",
      "amount": "4 sheets"
    },
    {
      "name": "resinous jelly broth",
      "amount": "2 cups"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "Soak the Chinese angelica in hot water for 10 minutes.",
    "Combine the soaked angelica, grated ginger, ground star anise, and ground cinnamon in a bowl.",
    "Place a slice of seared foie gras in the center of each papillote paper sheet.",
    "Spoon the angelica and spice mixture over the foie gras.",
    "Drizzle the resinous jelly broth over the top.",
    "Fold the papillote paper to form a Buddha Jumps Over Wall shape.",
    "Place the papillote in a molcajete vessel and bake for 12 minutes.",
    "Garnish with chopped scallions and serve immediately."
  ],
