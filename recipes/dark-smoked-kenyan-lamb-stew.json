    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "lamb broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat oil in a large Dutch oven over medium-high heat.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the onion, ginger, and spices, and cook until the onion is translucent, about 5 minutes.",
    "Add the molasses, carrots, potatoes, and lamb broth, and stir to combine.",
    "Bring the stew to a boil, then reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Stir in the smoked paprika and season with salt and pepper to taste.",
    "Serve the stew hot, garnished with fresh cilantro or parsley.",
    "Let the stew cool, then refrigerate or freeze for later use."
  ],
