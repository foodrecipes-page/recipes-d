    },
    {
      "name": "vegetable broth",
      "amount": "4 cups"
    },
    {
      "name": "apple cider vinegar",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Heat the donabe vessel over medium heat.",
    "Add the smoked paprika and cook for 1 minute, stirring constantly.",
    "Add the onion and garlic and cook until the onion is translucent.",
    "Add the beetroot, carrots, and potato, and cook for 5 minutes, stirring occasionally.",
    "Add the vegetable broth, apple cider vinegar, salt, and black pepper, and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 30 minutes.",
    "Serve hot, garnished with chopped fresh herbs if desired.",
    "Let the stew rest for 10 minutes before serving.",
    "Serve with crusty bread or over mashed potatoes."
  ],
