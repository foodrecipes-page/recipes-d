      "name": "chicken thighs",
      "amount": "1 1/2 pounds",
      "notes": "boneless and skinless"
    },
    {
      "name": "chicken stock concentrate",
      "amount": "2 tablespoons"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and cubed"
    },
    {
      "name": "onions",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "chopped"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "ground"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat 2 tablespoons of oil in a large pot over medium heat.",
    "Add the chopped onions and cook until they are translucent.",
    "Add the sliced carrots and cubed potatoes, and cook for 5 minutes.",
    "Add the chicken thighs and cook until they are browned on all sides.",
    "Add the chicken stock concentrate, thyme, black pepper, and salt, and stir to combine.",
    "Add 4 cups of water to the pot and bring to a boil.",
    "Reduce the heat to low and simmer for 30 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Serve hot and enjoy.",
    "Ensure poultry is cooked to an internal temperature of 74°C / 165°F (juices run clear, no pink remaining) before serving."
  ],
