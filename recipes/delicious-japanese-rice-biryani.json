    }
  ],
  "instructions": [
    "Heat the score-fat in a large pan over medium heat.",
    "Add the chopped onions and cook until they are translucent.",
    "Add the grated ginger and minced garlic and cook for another minute.",
    "Add the grated carrots and cook for 2 minutes.",
    "Add the green peas, turmeric, and salt, and cook for 1 minute.",
    "Add the Arabic rice and stir well to combine with the vegetables and spices.",
    "Add 4 cups of water to the pan and bring to a boil.",
    "Reduce the heat to low, cover the pan, and simmer for 20 minutes.",
    "Turn off the heat and let the biryani rest for 5 minutes before serving."
