{
  "title": "Deliciously Snappy Malaysian Egg Noodles",
  "description": "A festive Malaysian dish featuring egg noodles, toast, and a mustardy flavor, served in a banana leaf vessel, making it Buddhist-temple-friendly.",
  "cuisine": "Malaysian",
  "diet": [
    "vegetarian",
    "buddhist"
