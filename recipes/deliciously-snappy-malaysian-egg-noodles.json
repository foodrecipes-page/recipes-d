  "ingredients": [
    {
      "name": "egg noodles",
      "amount": "8 oz",
      "notes": "fresh"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "mustard seeds",
      "amount": "1 tsp"
    },
    {
      "name": "curry powder",
      "amount": "1 tsp"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "toasted bread",
      "amount": "4 slices"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "banana leaves",
      "amount": "4 pieces"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium heat.",
    "Add the mustard seeds and cook until they start to pop.",
    "Add the curry powder and cook for 1 minute, stirring constantly.",
    "Add the egg noodles and stir to combine with the curry powder mixture.",
    "Cook the noodles for 3-4 minutes, or until they are slightly browned.",
    "Stir in the soy sauce and cook for an additional 1-2 minutes.",
    "Toast the bread until it is lightly browned.",
    "Assemble the dish by placing the noodles on a banana leaf, topping with toasted bread and scallions.",
    "Serve immediately and enjoy."
  ],
