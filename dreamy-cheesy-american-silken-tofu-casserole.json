{
  "slug": "dreamy-cheesy-american-silken-tofu-casserole",
  "title": "Cheesy Tofu Casserole",
  "description": "A comforting, dreamy casserole filled with the goodness of tofu and cheese. Perfect for a cozy night in.",
  "cuisine": "American",
  "diet": [
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "silken tofu",
      "amount": "1 block (14 oz)",
      "notes": "drained and crumbled"
    },
    {
      "name": "cheese",
      "amount": "1 cup (shredded)",
      "notes": "cheddar or mozzarella work well"
    },
    {
      "name": "dreamy casserole mix",
      "amount": "1 package (8 oz)",
      "notes": "follow package instructions for seasoning"
    },
    {
      "name": "american cheese",
      "amount": "1/2 cup (shredded)",
      "notes": "for topping"
    },
    {
      "name": "paprika",
      "amount": "1 tsp",
      "notes": "optional, for extra flavor"
    },
    {
      "name": "salt and pepper",
      "amount": "",
      "notes": "to taste"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for greasing the baking dish"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Grease a 9x13 inch baking dish with olive oil.",
    "In a large mixing bowl, combine the crumbled tofu, shredded cheese, and casserole mix.",
    "Stir in the paprika and season with salt and pepper to taste.",
    "Transfer the mixture to the prepared baking dish.",
    "Sprinkle the shredded american cheese on top.",
    "Bake for 25-30 minutes, or until the cheese is melted and bubbly.",
    "Remove from oven and let cool for 5 minutes before serving."
  ],
