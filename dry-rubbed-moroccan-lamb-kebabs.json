  "instructions": [
    {
      "step": "1. Preheat grill to medium-high heat.",
      "notes": ""
    },
    {
      "step": "2. In a large bowl, whisk together Moroccan spice rub, olive oil, lemon juice, garlic, paprika, salt, and black pepper.",
      "notes": ""
    },
    {
      "step": "3. Add the lamb cubes to the bowl and toss to coat with the spice mixture.",
      "notes": ""
    },
    {
      "step": "4. Thread the lamb cubes onto skewers, leaving a small space between each piece.",
      "notes": ""
    },
    {
      "step": "5. Brush the grill grates with oil to prevent sticking.",
      "notes": ""
    },
    {
      "step": "6. Grill the lamb kebabs for 8-10 minutes, turning occasionally, or until cooked to your desired level of doneness.",
      "notes": ""
    },
    {
      "step": "7. Remove the kebabs from the grill and let rest for 5 minutes.",
      "notes": ""
    },
    {
      "step": "8. Sprinkle with parsley and serve hot.",
      "notes": ""
    }
